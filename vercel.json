{
	"version": 2,
	"builds": [
		{ "src": "static/**/*", "use": "@vercel/static" },
		{ "src": "sub-project/**/dist/**/*", "use": "@vercel/static" },
		{
			"src": "src/index.js",
			"use": "@vercel/node"
		}
	],
	"routes": [
		{
			"src": "/static/(.*)",
			"dest": "/static/$1"
		},
		{
			"src": "^/p/([^/]+)/(.*\\.\\w+)$",
			"dest": "/sub-project/$1/dist/$2"
		},
		{
			"src": "/api/(.*)",
			"dest": "/src/index.js"
		},
		{
			"src": "/(.*)",
			"dest": "/src/index.js"
		}
	],
	"functions": {
		"src/index.js": {
			"includeFiles": "**",
			"runtime": "nodejs20.x"
		}
	}
}
